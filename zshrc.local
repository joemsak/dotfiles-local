alias audacity=/Applications/Audacity.app/Contents/MacOS/Audacity

export KADENZE_SSH_USER=jsak
export GOPATH="$HOME/go"
export PATH="$GOPATH/bin:/usr/local/opt/postgresql@9.6/bin:$PATH"

# set yarn binaries on path
# must be below the .asdf source commands ^
export PATH="$(yarn global bin):$PATH"
eval "$(dip console)"
